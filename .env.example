# Doormat Configuration Example
# Copy to .env and fill in your values

# App
DEBUG=false
HOST=0.0.0.0
PORT=8000
API_VERSION=v1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=sqlite+aiosqlite:///./doormat.db
DATABASE_ECHO=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# OpenRouter (LLM) - Get API key from https://openrouter.ai
OPENROUTER_API_KEY=

# Apify (anti-bot fallback) - Optional, get API token from https://apify.com
APIFY_API_TOKEN=

# Cost tracking
TRACK_COSTS=true
