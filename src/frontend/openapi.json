            "type": "string"
          },
          "cost_usd": {
            "minimum": 0.0,
            "title": "Cost Usd",
            "type": "number"
          },
          "duration_seconds": {
            "minimum": 0.0,
            "title": "Duration Seconds",
            "type": "number"
          },
          "validated_count": {
            "minimum": 0.0,
            "title": "Validated Count",
            "type": "integer"
          }
        },
        "required": [
          "city",
          "candidates_found",
          "validated_count",
          "cost_usd",
          "duration_seconds"
        ],
        "title": "DiscoveryResult",
        "type": "object"
      },
      "ExtractionRequest": {
