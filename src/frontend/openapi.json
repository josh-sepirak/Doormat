  "components": {
    "schemas": {
      "CityStatus": {
        "properties": {
          "city": {
            "type": "string",
            "title": "City"
          },
          "managers_total": {
            "type": "integer",
            "title": "Managers Total"
          },
          "managers_validated": {
            "type": "integer",
            "title": "Managers Validated"
          },
          "has_been_discovered": {
            "type": "boolean",
            "title": "Has Been Discovered"
          }
        },
        "type": "object",
        "required": [
          "city",
          "managers_total",
          "managers_validated",
          "has_been_discovered"
        ],
        "title": "CityStatus",
        "description": "Discovery status for a city."
      },
      "DiscoveryResult": {
        "properties": {
          "city": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "City"
          },
          "candidates_found": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Candidates Found"
          },
          "validated_count": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Validated Count"
          },
          "cached": {
            "type": "boolean",
            "title": "Cached",
            "default": false
          },
          "cost_usd": {
            "type": "number",
            "minimum": 0.0,
            "title": "Cost Usd"
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0.0,
            "title": "Duration Seconds"
          }
        },
        "type": "object",
        "required": [
          "city",
          "candidates_found",
          "validated_count",
          "cost_usd",
          "duration_seconds"
        ],
        "title": "DiscoveryResult",
        "description": "Aggregate result of a city discovery run."
      },
      "ExtractionRequest": {
        "properties": {
          "property_manager_id": {
            "type": "string",
            "maxLength": 36,
            "minLength": 1,
            "title": "Property Manager Id"
          },
          "url": {
            "type": "string",
            "maxLength": 2083,
            "minLength": 1,
            "format": "uri",
            "title": "Url"
          },
          "html": {
            "type": "string",
            "maxLength": 2000000,
            "minLength": 1,
            "title": "Html"
          }
        },
        "type": "object",
        "required": [
          "property_manager_id",
          "url",
          "html"
        ],
        "title": "ExtractionRequest"
      },
      "ExtractionResponse": {
        "properties": {
          "status": {
            "type": "string",
            "const": "success",
            "title": "Status"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "title": "Confidence"
          },
          "mode": {
            "type": "string",
            "enum": [
              "A",
              "B"
            ],
            "title": "Mode"
          },
          "listing_address": {
            "type": "string",
            "title": "Listing Address"
          }
        },
        "type": "object",
        "required": [
          "status",
          "confidence",
          "mode",
          "listing_address"
        ],
        "title": "ExtractionResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ListingResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "property_manager_id": {
            "type": "string",
            "title": "Property Manager Id"
          },
          "preference_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Preference Id"
          },
          "address": {
            "type": "string",
            "title": "Address"
          },
          "bedrooms": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bedrooms"
          },
          "bathrooms": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bathrooms"
          },
          "sqft": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sqft"
          },
          "price": {
            "type": "number",
            "title": "Price"
          },
          "url": {
            "type": "string",
            "title": "Url"
          },
          "pets_policy": {
            "$ref": "#/components/schemas/PetsPolicy"
          },
          "amenities": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Amenities"
          },
          "photos": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Photos"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "extraction_timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Extraction Timestamp"
          },
          "extraction_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extraction Model"
          },
          "tier1_cost": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tier1 Cost"
          },
          "tier2_cost": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tier2 Cost"
          },
          "validation_passed": {
            "type": "boolean",
            "title": "Validation Passed"
          },
          "score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Score"
          },
          "score_explanation": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Score Explanation"
          },
          "saved": {
            "type": "boolean",
            "title": "Saved",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "id",
          "property_manager_id",
          "address",
          "price",
          "url",
          "pets_policy",
          "amenities",
          "photos",
          "extraction_timestamp",
          "validation_passed"
        ],
        "title": "ListingResponse",
        "description": "Listing response model."
      },
      "ManagerOut": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "city": {
            "type": "string",
            "title": "City"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "website": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Website"
          },
          "listing_page_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Listing Page Url"
          },
          "validated": {
            "type": "boolean",
            "title": "Validated"
          }
        },
        "type": "object",
        "required": [
          "id",
          "city",
          "name",
          "website",
          "listing_page_url",
          "validated"
        ],
        "title": "ManagerOut",
        "description": "Public representation of a discovered manager."
      },
      "PetsPolicy": {
        "type": "string",
        "enum": [
          "allowed_with_small_dog",
          "cats_only",
          "none_allowed",
          "unknown"
        ],
        "title": "PetsPolicy"
      },
      "TriggerRequest": {
        "properties": {
          "preference_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Preference Id"
          }
        },
        "type": "object",
        "title": "TriggerRequest",
        "description": "Optional body for POST trigger."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}